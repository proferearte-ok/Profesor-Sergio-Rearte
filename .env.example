# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- CONFIGURACIÓN DE GOOGLE SHEETS PARA CÁTEDRAS ---
VITE_SHEET_ID_BIOMOL_ASISTENCIA=
VITE_SHEET_ID_BIOMOL_NOTAS=
VITE_SHEET_ID_TECNOII_ASISTENCIA=
VITE_SHEET_ID_TECNOII_NOTAS=
VITE_SHEET_ID_TECNOIII_ASISTENCIA=
VITE_SHEET_ID_TECNOIII_NOTAS=

# --- SEGURIDAD Y CONFIGURACIÓN DOCENTE EN VIVO (PARTE A y B) ---
VITE_DOCENTE_PASSWORD=
VITE_SHEET_ID_PANEL_CONFIG=

# --- INTEGRACIÓN CON GOOGLE DRIVE API (LISTADO DINÁMICO) ---
VITE_GOOGLE_DRIVE_API_KEY=

